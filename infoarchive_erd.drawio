        <mxCell id="e_users_admins" value="1 : 0..1" style="endArrow=ERone;startArrow=ERone;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="users" target="admins"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_users_cart" value="1 : N" style="endArrow=ERmany;startArrow=ERone;html=1;rounded=0;strokeWidth=2;" edge="1" parent="1" source="users" target="cart"><mxGeometry relative="1" as="geometry" /></mxCell>
