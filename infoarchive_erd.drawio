<mxfile host="app.diagrams.net" modified="2026-05-20T00:00:00.000Z" agent="ChatGPT" version="24.7.17" type="device">
  <diagram id="infoarchive-erd" name="InfoArchive ERD">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="InfoArchive ERD 구조&#xa;users 안에 ADMIN role 포함 + admins 확장 테이블 포함" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=28;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="520" y="20" width="760" height="70" as="geometry" />
        </mxCell>

        <!-- USERS -->
        <mxCell id="users" value="users&#xa;────────────&#xa;PK id BIGINT&#xa;username VARCHAR UQ&#xa;password VARCHAR&#xa;name VARCHAR&#xa;email VARCHAR UQ&#xa;phone VARCHAR&#xa;role VARCHAR&#xa;  USER / INSTRUCTOR / ADMIN&#xa;membership_active BOOLEAN&#xa;membership_started_at DATETIME&#xa;membership_expired_at DATETIME&#xa;created_at DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f1ff;strokeColor=#2563eb;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="260" height="310" as="geometry" />
        </mxCell>

        <!-- ADMINS -->
        <mxCell id="admins" value="admins&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT UQ&#xa;admin_level VARCHAR&#xa;created_at DATETIME&#xa;&#xa;관리자 추가 정보" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7ef;strokeColor=#059669;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="150" width="240" height="170" as="geometry" />
        </mxCell>

        <!-- PRODUCT -->
        <mxCell id="product" value="product&#xa;────────────&#xa;PK id BIGINT&#xa;dtype VARCHAR&#xa;product_type VARCHAR&#xa;product_name VARCHAR&#xa;category VARCHAR&#xa;instructor_name VARCHAR&#xa;thumbnail_url VARCHAR&#xa;description TEXT&#xa;price INT&#xa;discount_rate INT&#xa;status VARCHAR&#xa;created_at DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7f7e7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="260" height="310" as="geometry" />
        </mxCell>

        <!-- CART -->
        <mxCell id="cart" value="cart&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK product_id BIGINT&#xa;quantity INT&#xa;created_at DATETIME&#xa;&#xa;UQ(user_id, product_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#f97316;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1090" y="120" width="260" height="190" as="geometry" />
        </mxCell>

        <!-- WISHLIST -->
        <mxCell id="wish_list" value="wish_list&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK product_id BIGINT&#xa;created_at DATETIME&#xa;&#xa;UQ(user_id, product_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe8ef;strokeColor=#e11d48;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1090" y="350" width="260" height="170" as="geometry" />
        </mxCell>

        <!-- ENROLLMENT -->
        <mxCell id="enrollment" value="enrollment&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK product_id BIGINT&#xa;progress_rate INT&#xa;enrolled_at DATETIME&#xa;expired_at DATETIME&#xa;created_at DATETIME&#xa;&#xa;UQ(user_id, product_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#f97316;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1090" y="560" width="260" height="230" as="geometry" />
        </mxCell>

        <!-- PAYMENT -->
        <mxCell id="payment" value="payment&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK product_id BIGINT NULL&#xa;FK user_coupon_id BIGINT NULL&#xa;order_number VARCHAR UQ&#xa;payment_status VARCHAR&#xa;payment_method VARCHAR&#xa;original_amount INT&#xa;discount_amount INT&#xa;final_amount INT&#xa;order_date DATETIME&#xa;&#xa;※ product_id는 멤버십 결제 시 NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7db;strokeColor=#d97706;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1450" y="140" width="300" height="330" as="geometry" />
        </mxCell>

        <!-- COUPON -->
        <mxCell id="coupon" value="coupon&#xa;────────────&#xa;PK id BIGINT&#xa;coupon_name VARCHAR&#xa;coupon_code VARCHAR UQ&#xa;discount_amount INT&#xa;min_order_amount INT&#xa;active BOOLEAN&#xa;created_at DATETIME&#xa;expired_at DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#9333ea;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1450" y="530" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- USER_COUPON -->
        <mxCell id="user_coupon" value="user_coupon&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK coupon_id BIGINT&#xa;status VARCHAR&#xa;  AVAILABLE / USED / EXPIRED&#xa;issued_at DATETIME&#xa;used_at DATETIME&#xa;&#xa;UQ(user_id, coupon_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#9333ea;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1450" y="810" width="300" height="230" as="geometry" />
        </mxCell>

        <!-- REVIEW -->
        <mxCell id="review" value="review&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;FK product_id BIGINT&#xa;rating INT&#xa;content TEXT&#xa;created_at DATETIME&#xa;&#xa;UQ(user_id, product_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#0891b2;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="260" height="200" as="geometry" />
        </mxCell>

        <!-- INSTRUCTOR APPLY -->
