          <mxGeometry x="380" y="520" width="280" height="280" as="geometry" />
        </mxCell>

        <!-- CUSTOMER INQUIRY -->
        <mxCell id="customer_inquiry" value="customer_inquiry&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;category VARCHAR&#xa;title VARCHAR&#xa;content TEXT&#xa;answer TEXT&#xa;status VARCHAR&#xa;  WAITING / ANSWERED&#xa;created_at DATETIME&#xa;answered_at DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#0891b2;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="790" width="260" height="260" as="geometry" />
        </mxCell>

        <!-- COMMUNITY -->
        <mxCell id="community_posts" value="community_posts&#xa;────────────&#xa;PK id BIGINT&#xa;FK user_id BIGINT&#xa;title VARCHAR&#xa;content TEXT&#xa;created_at DATETIME&#xa;updated_at DATETIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#0891b2;fontSize=13;fontStyle=1;align=left;spacingLeft=12;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="850" width="280" height="190" as="geometry" />
        </mxCell>

        <!-- SUMMARY -->
        <mxCell id="summary" value="핵심 정리&#xa;────────────&#xa;• 회원/관리자는 users.role로 구분&#xa;• admins는 관리자 추가 정보용 확장 테이블&#xa;• 상품/강의는 product 기준으로 통일&#xa;• cart, wish_list, enrollment 모두 product_id 사용&#xa;• coupon은 원본, user_coupon은 회원 보유 쿠폰&#xa;• payment는 쿠폰 적용 금액까지 저장" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=14;fontStyle=1;align=left;spacingLeft=14;verticalAlign=top;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="850" width="520" height="190" as="geometry" />
        </mxCell>

